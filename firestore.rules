rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /files/{fileId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if false;
      }
      match /google_tokens/{module} { allow read, write: if false; }
      match /integrations/{integration} { allow read, write: if false; }
    }

    match /conversations/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /usage/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /pending_signups/{docId} {
      allow read, write: if request.auth != null;
    }

    match /api_keys/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /site_metrics/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /creations/{creationId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null;
      }
    }

    // ── Orin Builder projects ──────────────────────────────────────────────────
    match /builder_projects/{projectId} {
      // 'read' covers both get (single doc) and list (queries)
      allow read:   if request.auth != null
                    && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }
  }
}
